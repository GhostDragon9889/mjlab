    over "Physics"
    {
        over "PhysicsMaterial" (
            prepend apiSchemas = ["PhysicsMaterialAPI", "NewtonMaterialAPI"]
        )
        {
            float newton:rollingFriction = 0.0001
            float newton:torsionalFriction = 0.005
            float physics:dynamicFriction = 1
        }
    }
}

def PhysicsScene "PhysicsScene" (
    prepend apiSchemas = ["NewtonSceneAPI"]
)
{
    uniform int newton:maxSolverIterations = 100
    uniform int newton:timeStepsPerSecond = 500
    vector3f physics:gravityDirection = (0, 0, -1)
    float physics:gravityMagnitude = 9.81
}

